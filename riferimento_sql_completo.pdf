1 0 0 1 25.84252 114.8331 cm
%PreformattedPara
0 0 0 rg
BT 1 0 0 1 0 419.9 Tm /F3 6.7 Tf 7.9 TL (WITH clienti_filtrati AS \() Tj T* (    SELECT) Tj T* (        id, nome, cognome, citt\340, et\340, email, telefono, indirizzo) Tj T* (    FROM clienti) Tj T* (    WHERE et\340 >= 18) Tj T* (      AND citt\340 IN \('Roma', 'Milano', 'Napoli'\)) Tj T* (\),) Tj T* (ordini_base AS \() Tj T* (    SELECT) Tj T* (        o.id, o.cliente_id, o.importo, o.data_ordine,) Tj T* (        ROW_NUMBER\(\) OVER \() Tj T* (            PARTITION BY o.cliente_id) Tj T* (            ORDER BY o.importo DESC) Tj T* (        \) AS rn_importo) Tj T* (    FROM ordini o) Tj T* (    WHERE o.importo > 10) Tj T* (\)) Tj T* (SELECT) Tj T* (    c.id AS cliente_id,) Tj T* (    UPPER\(c.nome\) AS nome_upper,) Tj T* (    LOWER\(c.cognome\) AS cognome_lower,) Tj T* (    CONCAT\(c.nome, ' ', c.cognome\) AS nome_completo,) Tj T* (    CONCAT_WS\(' - ' , c.nome, c.cognome, c.citt\340\) AS nome_cognome_citt\340,) Tj T* (    LEFT\(c.nome, 3\) AS iniziale_nome,) Tj T* (    RIGHT\(c.telefono, 3\) AS ultime_3_cifre,) Tj T* (    SUBSTRING\(c.email, 1, 5\) AS email_inizio,) Tj T* (    POSITION\('@' IN c.email\) AS posizione_at,) Tj T* (    LENGTH\(c.email\) AS lunghezza_email,) Tj T* (    EXTRACT\(MONTH FROM o.data_ordine\) AS mese_ordine,) Tj T* (    EXTRACT\(YEAR FROM o.data_ordine\) AS anno_ordine,) Tj T* (    CAST\(o.importo AS INT\) AS importo_intero,) Tj T* (    COALESCE\(c.telefono, c.email, 'N/D'\) AS contatto,) Tj T* (    CASE) Tj T* (        WHEN o.importo > 1000 THEN 'Alto') Tj T* (        WHEN o.importo > 500 THEN 'Medio') Tj T* (        ELSE 'Basso') Tj T* (    END AS fascia_importo,) Tj T* (    o.rn_importo,) Tj T* (    COUNT\(*\) AS totale_righe,) Tj T* (    COUNT\(DISTINCT o.id\) AS ordini_unici,) Tj T* (    SUM\(o.importo\) AS fatturato_totale,) Tj T* (    AVG\(o.importo\) AS importo_medio,) Tj T* (    MIN\(o.data_ordine\) AS primo_ordine,) Tj T* (    MAX\(o.importo\) AS ordine_max) Tj T* (FROM clienti_filtrati c) Tj T* (INNER JOIN ordini_base o ON c.id = o.cliente_id) Tj T* (WHERE c.email IS NOT NULL) Tj T* (  AND c.nome LIKE 'A%') Tj T* (GROUP BY) Tj T* (    c.id, c.nome, c.cognome, c.citt\340, c.email, c.telefono,) Tj T* (    o.id, o.importo, o.data_ordine, o.rn_importo) Tj T* (HAVING COUNT\(*\) >= 1) Tj T* (ORDER BY fatturato_totale DESC, nome_completo ASC) Tj T* (LIMIT 20 OFFSET 0;) Tj T* ET
Q
 

endstream
